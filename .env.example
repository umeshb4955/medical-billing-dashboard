# === MEDICAL BILLING DASHBOARD - ENVIRONMENT CONFIG ===

# Application Environment
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-app-name.vercel.app

# ============ DATABASE (Choose One) ============

# Option 1: SQLite (Local development only - won't work in production)
# DB_TYPE=sqlite
# DB_PATH=./billing.db

# Option 2: PostgreSQL (RECOMMENDED for production on AWS RDS, Azure Database, etc.)
DB_TYPE=postgresql
DATABASE_URL=postgresql://username:password@host:5432/medical_billing_db

# Option 3: MongoDB (Use MongoDB Atlas free tier)
# DB_TYPE=mongodb
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/medical_billing_db

# ============ SECURITY ============
AUTH_SECRET=generate-a-random-secret-here-at-least-32-chars
SESSION_TIMEOUT_MINUTES=480

# ============ VERCEL DEPLOYMENT ONLY ============
# Leave as-is for Vercel (set automatically)
# VERCEL=1
# VERCEL_ENV=production

# ============ OPTIONAL FEATURES ============
# PDF_EXPORT=true
# EMAIL_NOTIFICATIONS=false
